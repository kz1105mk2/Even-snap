{
  "manifest_version": 3,
  "name": "EventSnap",
  "version": "1.0.1",
  "key": "",
  "description": "Webページ上のイベント日時を選択し、右クリックからGoogle Calendarに予定を登録",
  "permissions": [
    "contextMenus",
    "activeTab",
    "identity",
    "storage",
    "windows"
  ],
  "host_permissions": [
    "https://www.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html"
  },
  "options_page": "options/options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "oauth2": {
    "client_id": "719794860523-38cgh32jpksguk96p1gpqdlactq0rvi6.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/calendar"
    ]
  }
}
